@page "/employees"
@using evidence_zamestancu.Client.Models
@inject HttpClient Http

<PageTitle>Employees</PageTitle>

<h1>List of employees</h1>

<p>This page displays all employees from our database.</p>

@if (employees == null)
{
    <p><em>Loading data from the server...</em></p>
}
else if (employees.Count == 0)
{
    <div class="alert alert-warning">
        There are currently no employees in the database. The table is empty!
    </div>
}
else
{
    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Surname</th>
            <th>BirthDate</th>
            <th>Position</th>
            <th>IP Address</th>
            <th>IP Country code</th>
        </tr>
        </thead>
        
        <tbody>
             @foreach (var emp in employees)
             {
                 <tr>
                     <td>@emp.Name</td>
                     <td>@emp.Surname</td>
                     <td>@emp.BirthDate</td>
                     <td>@(emp.Position?.PositionName ?? "No position")</td>
                     <td>@emp.IPaddress</td>
                     <td>@emp.IPCountryCode</td>
                 </tr>
             }
        </tbody>
    </table>
}



@code{
    private List<Employee>? employees;

    protected override async Task OnInitializedAsync()
    {
        employees = await Http.GetFromJsonAsync<List<Employee>>("https://localhost:7248/api/Employees");
    }

}